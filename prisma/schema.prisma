// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Commercant {
  id                Int   @id @default(autoincrement())
  nom               String
  prenom            String
  telephone         String   @unique
  email             String   @unique
  motDePasse        String
  nomBoutique       String
  description       String?
  ville             String
  quartier          String
  pays              String
  isAbonne          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clients           Client[]
  produits          Produit[]
  credits           Credit[]
}

model Client {
  id           Int   @id @default(autoincrement())
  commercantId Int
  nom          String
  prenom       String
  telephone    String
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  commercant   Commercant @relation(fields: [commercantId], references: [id])
  credits      Credit[]
}

model Credit {
  id            Int   @id @default(autoincrement())
  commercantId  Int
  clientId      Int
  montantTotal  Float
  montantPaye   Float   @default(0)
  statutCredit  StatutCredit @default(NON_PAYE)
  dateCredit    DateTime @default(now())
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  commercant    Commercant @relation(fields: [commercantId], references: [id])
  client        Client     @relation(fields: [clientId], references: [id])
  paiements     Paiement[]
  produits      CreditProduit[]
}

model Paiement {
  id           Int   @id @default(autoincrement())
  creditId     Int
  montant      Float
  datePaiement DateTime @default(now())
  createdAt    DateTime @default(now())

  credit       Credit @relation(fields: [creditId], references: [id])
}

model Produit {
  id            Int   @id @default(autoincrement())
  commercantId  Int
  nom           String
  prixUnitaire  Float
  unite         UniteProduit
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt

  commercant    Commercant @relation(fields: [commercantId], references: [id])
  credits       CreditProduit[]
}

model CreditProduit {
  id            Int   @id @default(autoincrement())
  creditId      Int
  produitId     Int
  quantite      Float
  prixUnitaire  Float
  montantTotal  Float

  credit        Credit  @relation(fields: [creditId], references: [id])
  produit       Produit @relation(fields: [produitId], references: [id])
}

enum StatutCredit {
  NON_PAYE
  EN_COURS
  PAYE
}

enum UniteProduit {
  SAC
  KILO
  LIBAR
  LITRE
  SACHET
  CARTON
  BOITE
  BOUTEILLE
  BIDON
  METRE
  PAQUET
}
