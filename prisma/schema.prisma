// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Commercant {
  id                Int   @id @default(autoincrement())
  nom               String
  prenom            String
  telephone         String   @unique
  email             String   @unique
  motDePasse        String
  nomBoutique       String
  description       String?
  ville             String
  quartier          String
  pays              String
  essaiFinLe        DateTime @default(now())
  role              Role @default(COMMERCANT)
  abonneJusquau     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clients           Client[]
  produits          Produit[]
  credits           Credit[]
  paiementsAbo      PaiementAbonnement[]
  boutique          Boutique?
  commandes         Commande[]
}

model Client {
  id           Int   @id @default(autoincrement())
  commercantId Int
  nom          String
  prenom       String
  telephone    String
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  commercant   Commercant @relation(fields: [commercantId], references: [id])
  credits      Credit[]
}

model Credit {
  id            Int   @id @default(autoincrement())
  commercantId  Int
  clientId      Int
  montantTotal  Float
  montantPaye   Float   @default(0)
  statutCredit  StatutCredit @default(NON_PAYE)
  dateCredit    DateTime @default(now())
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  commercant    Commercant @relation(fields: [commercantId], references: [id])
  client        Client     @relation(fields: [clientId], references: [id])
  paiements     Paiement[]
}

model Paiement {
  id           Int   @id @default(autoincrement())
  creditId     Int
  montant      Float
  datePaiement DateTime @default(now())
  createdAt    DateTime @default(now())

  credit       Credit @relation(fields: [creditId], references: [id])
}

model Produit {
  id            Int   @id @default(autoincrement())
  commercantId  Int
  nom           String
  prix          Float
  categorie     CategorieProduit @default(AUTRES)
  description   String?
  disponible    Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt

  commercant    Commercant @relation(fields: [commercantId], references: [id])
  images        ProduitImage[]
  lignesCommande LigneCommande[]
}

enum StatutCredit {
  NON_PAYE
  EN_COURS
  PAYE
}

// enum UniteProduit {
//   SAC
//   KILO
//   LIBAR
//   LITRE
//   SACHET
//   CARTON
//   BOITE
//   BOUTEILLE
//   BIDON
//   METRE
//   PAQUET
// }

enum CategorieProduit {
  ALIMENTAIRE
  BOISSONS
  HYGIENE
  VETEMENTS
  AUTRES
}

model MessageContact {
  id        Int      @id @default(autoincrement())
  prenom    String
  nom       String
  email     String
  sujet     String
  message   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PaiementAbonnement {
  id           Int                @id @default(autoincrement())
  commercantId Int
  methode      MethodePaiement
  montant      Float
  captureUrl   String             // capture d'écran du paiement (Supabase Storage)
  statut       StatutPaiementAbo  @default(EN_ATTENTE)
  motifRejet   String?            // si l'admin rejette
  verifieLe    DateTime?
  createdAt    DateTime           @default(now())

  commercant   Commercant @relation(fields: [commercantId], references: [id])
}

model Boutique {
  id            Int      @id @default(autoincrement())
  commercantId  Int      @unique   
  slug          String   @unique   // l'URL : shopbook.mr/boutique/[slug]
  nom           String             
  description   String?             
  quartier      String?             
  telephone     String?
  active        Boolean  @default(true)
  livraison     Boolean  @default(false)
  retrait       Boolean  @default(true)  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  commercant    Commercant @relation(fields: [commercantId], references: [id], onDelete: Cascade)
}

model ProduitImage {
  id         Int      @id @default(autoincrement())
  produitId  Int
  url        String            // URL publique dans le bucket "produits"
  ordre      Int      @default(0)
  createdAt  DateTime @default(now())

  produit    Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
}

enum MethodePaiement {
  BANKILY
  MASRVI
  SEDAD
  AUTRE
}

enum StatutPaiementAbo {
  EN_ATTENTE   // soumis → accès provisoire accordé
  APPROUVE     // admin a confirmé la réception
  REJETE       // argent non reçu → accès bloqué
}

enum Role {
  COMMERCANT
  ADMIN
}

model Acheteur {
  id         Int      @id @default(autoincrement())
  nom        String
  telephone  String   @unique   // identifiant de connexion
  motDePasse String              // haché (bcrypt)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  commandes  Commande[]
}

model Commande {
  id            Int      @id @default(autoincrement())
  acheteurId    Int
  commercantId  Int                  // à quelle boutique (via le commerçant)
  mode          ModeCommande
  adresse       String?              // requise si mode = LIVRAISON
  statut        StatutCommande   @default(NOUVELLE)   // logistique
  statutPaiement StatutPaiementCommande @default(EN_ATTENTE)
  total         Float                // figé à la création
  note          String?              // message optionnel du client
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  acheteur      Acheteur     @relation(fields: [acheteurId], references: [id])
  commercant    Commercant   @relation(fields: [commercantId], references: [id], onDelete: Cascade)
  lignes        LigneCommande[]
}

model LigneCommande {
  id           Int      @id @default(autoincrement())
  commandeId   Int
  produitId    Int?                  // référence (nullable : le produit peut être supprimé plus tard)
  nomProduit   String                // figé au moment de la commande
  prixUnitaire Float                 // figé au moment de la commande
  quantite     Int

  commande     Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit      Produit? @relation(fields: [produitId], references: [id], onDelete: SetNull)
}

enum ModeCommande {
  LIVRAISON
  RETRAIT
}

enum StatutCommande {
  NOUVELLE         // reçue, pas encore prise en charge
  EN_PREPARATION   // le commerçant prépare
  PRETE            // prête pour retrait (mode RETRAIT)
  EN_LIVRAISON     // en cours de livraison (mode LIVRAISON)
  RECUPEREE        // retirée par le client (final)
  LIVREE           // livrée au client (final)
  REFUSEE          // refusée par le commerçant
  ANNULEE          // annulée par le client
}

enum StatutPaiementCommande {
  EN_ATTENTE       // pas encore payée
  PAYEE            // payée à la remise
}